.env
__pycache__/
.venv/

# Перекачиваемый кэш котировок (источник истины — EODHD; запечатанные журналы остаются в git)
storage/*.db
storage/*.db-wal
storage/*.db-shm

# Генерируемый вывод дашборда
dashboard/*.html

# Регенерируемые операционные логи (не запечатанные журналы прогнозов)
journal/news_ingest.log
journal/cron.log
journal/reminders.log
journal/bot.log

# Внутреннее мутабельное состояние бота-пульта (дедуп пушей/алертов) — НЕ журнал
journal/bot_state.json

# Локальные (НЕ «Оракул») задачи cron сторонних сервисов + их секреты — FГ2 (§9.3):
# вынесены из committed ops/crontab.txt, чтобы плейн-текст токенов не попадал в git.
ops/crontab.local.txt
# Рабочие бэкапы УСТАНОВЛЕННОГО crontab (crontab -l перед правкой) — содержат тот же
# сторонний токен; НИКОГДА не в git (иначе секрет утечёт через git add -A).
ops/crontab_installed.bak*.txt
ops/crontab*.bak*

# системный бэкап sshd — не артефакт проекта
ops/sshd_backup/
